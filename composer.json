{
    "name": "omarbpay/laravel-passport-phone-verification-code-grant",
    "description": "Resource owner phone verification code credentials grant for Laravel Passport, fork of qiutuleng/laravel-passport-phone-verification-code-grant",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Faruk",
            "email": "omar@itopup.co"
        }
    ],
    "require": {
        "php": "^7.2 || ^8.0",
        "laravel/passport": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "QiuTuleng\\PhoneVerificationCodeGrant\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "QiuTuleng\\PhoneVerificationCodeGrant\\PhoneVerificationCodeGrantServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev"
}
